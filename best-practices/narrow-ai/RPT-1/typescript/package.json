{
  "name": "rpt1-typescript-sample",
  "version": "1.0.0",
  "description": "Inference-only SAP RPT-1 TypeScript SDK showcase",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "predict:without-schema": "node dist/index.js without-schema",
    "predict:with-schema": "node dist/index.js with-schema",
    "predict:all": "node dist/index.js all"
  },
  "dependencies": {
    "@sap-ai-sdk/rpt": "2.8.0",
    "dotenv": "16.4.7"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "tsx": "4.19.3",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
